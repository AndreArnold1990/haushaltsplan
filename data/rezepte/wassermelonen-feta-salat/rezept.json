  "steps": {
    "de": [
      "Wassermelone in mundgerechte Würfel schneiden.",
      "Zwiebel in sehr feine Ringe schneiden, Minze waschen und grob zupfen.",
      "Alles auf einer Platte anrichten und den Feta darüberbröseln.",
      "Mit Olivenöl und Limettensaft beträufeln, mit Pfeffer abschmecken.",
      "Gut gekühlt servieren."
    ],
    "es": [
      "Cortar la sandía en dados.",
      "Cortar la cebolla en aros muy finos, lavar la menta y trocearla.",
      "Disponer todo en una fuente y desmenuzar el feta por encima.",
      "Rociar con el aceite y el zumo de lima, sazonar con pimienta.",
      "Servir bien frío."
    ]
  },
  "notes": {
    "de": "Feta aus pasteurisierter Milch verwenden. Erfrischender geht Sommer kaum.",
    "es": "Usar feta de leche pasteurizada. Difícil encontrar algo más refrescante en verano."
