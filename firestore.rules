rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config/allowlist ist für keinen Client lesbar oder schreibbar —
    // nur die Rules-Engine hat via get() Zugriff darauf.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Haushalt-Dokument inkl. aller Unterkollektionen (z.B. backups):
    // Zugriff nur mit verifizierter E-Mail, die in config/allowlist steht.
    match /households/{householdId}/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.token.email_verified == true
        && householdId == 'haushaltsplan-16082'
        && request.auth.token.email in
             get(/databases/$(database)/documents/config/allowlist).data.emails;
    }

  }
}
